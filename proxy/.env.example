# Variables esperadas por proxy/docker-compose.yml
# Cargar los valores reales en Portainer > Stack "Proxy" > Environment variables.
# NUNCA completar este archivo con valores reales ni versionarlo en git con datos sensibles.

# Carpeta raíz de este stack en el host, montada completa como /config
# (todo el config de SWAG vive plano acá, sin subcarpeta adicional).
BASE_DIR=/ruta/al/volumen/de/proxy
URL=tu-dominio.example.com
EMAIL=tu-email@example.com
# Dominios extra para el mismo certificado (SAN), separados por coma.
# Hoy se usa para exponer immich-app en un dominio aparte (no subdominio —
# el plan gratuito de noip.com no lo permite), ver docs/ARCHITECTURE.md.
EXTRA_DOMAINS=photoskamehousecr.ddns.net
