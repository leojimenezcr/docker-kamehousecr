# Variables esperadas por stacks/jellyfin/docker-compose.yml
# Cargar los valores reales en Portainer > Stack "jellyfin" > Environment variables.
# NUNCA completar este archivo con valores reales ni commitearlo con datos sensibles.
#
# Este stack usa env_file: ../../stack.env — ver aviso crítico en
# docs/PORTAINER-SETUP.md sobre la ruta relativa de ese archivo tras la
# reorganización.

BASE_DIR=/ruta/al/volumen/de/jellyfin
MEDIA_DIR=/ruta/al/volumen/de/medios
TRANSMISSION_USER=usuario_transmission_webui
TRANSMISSION_PASS=contraseña_transmission_webui
TINYMEDIAMANAGER_PASSWORD=contraseña_tinymediamanager
