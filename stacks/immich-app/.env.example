# Variables esperadas por stacks/immich-app/docker-compose.yml
# Cargar los valores reales en Portainer > Stack "immich-app" > Environment variables.
# NUNCA completar este archivo con valores reales ni versionarlo en git con datos sensibles.
#
# Este stack usa env_file: ../../stack.env — ver aviso crítico en
# docs/PORTAINER-SETUP.md sobre la ruta relativa de ese archivo tras la
# reorganización.

IMMICH_VERSION=release
UPLOAD_LOCATION=/ruta/al/volumen/de/immich/upload
BASE_DIR=/ruta/al/volumen/de/immich
DB_USERNAME=usuario_postgres
DB_PASSWORD=contraseña_postgres
DB_DATABASE_NAME=nombre_basededatos
