# Variables esperadas por stacks/duplicati/docker-compose.yml
# Cargar los valores reales en Portainer > Stack "duplicati" > Environment variables.
# NUNCA completar este archivo con valores reales ni versionarlo en git con datos sensibles.

DUPLICATI_CONFIG_DIR=/ruta/al/volumen/de/duplicati/config
DUPLICATI_BACKUPS_DIR=/ruta/al/volumen/de/duplicati/backups

# ADVERTENCIA: en la configuración actual esta variable apunta al $HOME completo
# del host (bind mount de todo el directorio home del usuario como origen de
# respaldo). Se preserva tal cual para no romper funcionalidad — no se reduce
# el alcance en esta reorganización. Ver docs/ARCHITECTURE.md.
DUPLICATI_SOURCE_DIR=/ruta/al/directorio/de/origen/a/respaldar
