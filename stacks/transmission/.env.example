# Variables esperadas por stacks/transmission/docker-compose.yml
# Cargar los valores reales en Portainer > Stack "transmission" > Environment variables.
# NUNCA completar este archivo con valores reales ni versionarlo en git con datos sensibles.

# Carpeta raíz de este stack en el host; contiene config/, downloads/ y watch/.
BASE_DIR=/ruta/al/volumen/de/transmission

# NOTA: nombres de variable genéricos (USER/PASS) heredados del compose
# original; riesgo de colisión con variables de entorno del shell/sistema
# (USER suele estar seteada por el SO). No se renombran aquí (fuera de
# alcance funcional) — ver docs/ARCHITECTURE.md.
USER=usuario_webui
PASS=contraseña_webui
