# Variables esperadas por stacks/Nextcloud/docker-compose.yml
# Cargar los valores reales en Portainer > Stack "Nextcloud" > Environment variables.
# NUNCA completar este archivo con valores reales ni commitearlo con datos sensibles.
#
# Este stack usa env_file: ../../stack.env — ver aviso crítico en
# docs/PORTAINER-SETUP.md sobre la ruta relativa de ese archivo tras la
# reorganización.

NEXTCLOUD_DATA_DIR=/ruta/al/volumen/de/nextcloud/data
NEXTCLOUD_DB_DIR=/ruta/al/volumen/de/nextcloud/db
MYSQL_HOST=nombre_host_o_servicio_mysql
MYSQL_USER=usuario_mysql
MYSQL_PASSWORD=contraseña_mysql
MYSQL_DATABASE=nombre_basededatos
MYSQL_ROOT_PASSWORD=contraseña_root_mysql
