# Copiar este archivo a scripts/webhooks.env (NO commitear ese archivo, ya
# está listado en .gitignore) y completar con las URLs de webhook reales de
# cada stack.
#
# Cómo conseguir la URL real de un stack:
#   Portainer UI > Stacks > <nombre> > "Redeploy from git repository" >
#   activar "GitOps updates" > Mechanism: Webhook > botón "Copy link".
#
# IMPORTANTE: el botón "Copy link" da una URL con el puerto directo de
# Portainer (ej. https://tu-dominio:9443/api/stacks/webhooks/<uuid>). Esa
# URL no sirve tal cual: ese puerto expone el certificado autofirmado de
# Portainer (no el de Let's Encrypt de SWAG), y curl rechaza la conexión
# (SSL: no alternative certificate subject name matches). Hay que
# reescribirla a mano para que pase por el proxy, cambiando "<dominio>:9443"
# por "<dominio>/portainer":
#   https://tu-dominio:9443/api/stacks/webhooks/<uuid>
#   -> https://tu-dominio/portainer/api/stacks/webhooks/<uuid>
# (requiere el location block dedicado en proxy/conf.d/default.conf — ver
# docs/PORTAINER-SETUP.md). El puerto 9443 se deja abierto solo para entrar
# directo a Portainer si el proxy está caído, no para webhooks.
#
# Nombre de variable: WEBHOOK_<NOMBRE_STACK_EN_MAYUSCULAS_CON_GUION_BAJO>
# (mismo nombre de carpeta bajo stacks/, o "PROXY" para el proxy).
#
# Los valores de abajo son placeholders, NO son webhooks reales.

WEBHOOK_DUPLICATI=https://portainer.example.com/portainer/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_IMMICH_APP=https://portainer.example.com/portainer/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_ISP_MONITOR=https://portainer.example.com/portainer/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_JELLYFIN=https://portainer.example.com/portainer/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_NAVIDROME=https://portainer.example.com/portainer/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_NEXTCLOUD=https://portainer.example.com/portainer/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_PORTAINER=https://portainer.example.com/portainer/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_PROXY=https://portainer.example.com/portainer/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_WATCHTOWER=https://portainer.example.com/portainer/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
