# Copiar este archivo a scripts/webhooks.env (NO commitear ese archivo, ya
# está listado en .gitignore) y completar con las URLs de webhook reales de
# cada stack.
#
# Cómo conseguir la URL real de un stack:
#   Portainer UI > Stacks > <nombre> > "Redeploy from git repository" >
#   activar "GitOps updates" > Mechanism: Webhook > botón "Copy link".
#
# La URL que da "Copy link" se puede pegar tal cual, sin reescribirla:
#   https://tu-dominio/api/stacks/webhooks/<uuid>
# (requiere el location block dedicado en proxy/conf.d/default.conf — ver
# docs/PORTAINER-SETUP.md). Si en cambio la URL viene con el puerto directo
# de Portainer (https://tu-dominio:9443/...), es porque se copió con el
# navegador apuntando directo a ese puerto en vez de a /portainer/ — ese
# puerto expone el certificado autofirmado de Portainer (no el de Let's
# Encrypt de SWAG) y curl rechaza la conexión. Volver a copiar el link
# desde /portainer/ en ese caso.
#
# Nombre de variable: WEBHOOK_<NOMBRE_STACK_EN_MAYUSCULAS_CON_GUION_BAJO>
# (mismo nombre de carpeta bajo stacks/, o "PROXY" para el proxy).
#
# Los valores de abajo son placeholders, NO son webhooks reales.

WEBHOOK_DUPLICATI=https://portainer.example.com/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_IMMICH_APP=https://portainer.example.com/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_ISP_MONITOR=https://portainer.example.com/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_JELLYFIN=https://portainer.example.com/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_NAVIDROME=https://portainer.example.com/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_NEXTCLOUD=https://portainer.example.com/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_PORTAINER=https://portainer.example.com/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_PROXY=https://portainer.example.com/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
WEBHOOK_WATCHTOWER=https://portainer.example.com/api/stacks/webhooks/00000000-0000-0000-0000-000000000000
